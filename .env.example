# Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Notion — multi-tenant config
# Keys: database IDs with dashes removed (visible in Notion DB URL)
# Each user creates their own Notion integration and shares their secret + DB ID
NOTION_TENANTS={"8d533a1b0d2a4a77b011efd67d3b726f": {"api_key": "secret_...", "name": "Felipe"}, "<jon_db_id>": {"api_key": "secret_...", "name": "Jon"}, "<oli_db_id>": {"api_key": "secret_...", "name": "Oli"}}

# Google Drive (Service Account)
GOOGLE_DRIVE_FOLDER_ID=...
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}
